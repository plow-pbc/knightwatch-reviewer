[Unit]
Description=Plow PR reviewer (multi-specialist codex)
Documentation=https://github.com/cncorp/plow
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# KillMode=process so workers survive the orchestrator's exit. With the
# default `control-group` mode, systemd would kill every process in the
# unit's cgroup when ExecStart returns — including the detached workers
# review.sh just spawned. With `process`, only the main process (review.sh)
# is tracked for kill purposes; workers reparent to PID 1 and run to
# completion independently.
KillMode=process
User=odio
Group=odio
WorkingDirectory=/home/odio/.pr-reviewer
Environment=HOME=/home/odio
# PATH: system dirs FIRST so `timeout`, `bash`, `gh`, `git`, etc.
# resolve to /usr/bin paths regardless of any user-dir ordering.
# /home/odio/.local is NOT in ReadWritePaths (per the rationale on the
# ReadWritePaths line below), so ~/.local/bin tool replacements are
# blocked at the sandbox level too. User-installed tools (codex via
# npm-global, pipx, etc.) remain reachable via the trailing user dirs.
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/home/odio/.npm-global/bin:/home/odio/.local/bin
ExecStart=/home/odio/.pr-reviewer/review.sh
TimeoutStartSec=90min
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pr-reviewer

# Light sandbox — chosen to not break `just test` in tracked repos.
NoNewPrivileges=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
ProtectHome=read-only
# @KID_INDEX_RW_PATHS@ is rendered at install time by install.sh from
# repos.conf's KID_PATHS values, suffixed with `/.keepitdry` and
# prefixed with `-` so missing index dirs don't fail unit start. The
# kid prior-art lookup opens chromadb at
# `<KID_PATH>/.keepitdry/chroma.sqlite3`, and chromadb's SQLite backend
# needs to write WAL/journal files even on read-only queries. Without
# write access, queries fail with "attempt to write a readonly
# database" under ProtectHome=read-only and every review silently
# degrades to kid-less. Narrower than the kid-refresh render
# (@KID_RW_PATHS@): review specialists run with Codex's inner sandbox
# disabled and don't need writes outside the index dir. Do not edit
# @KID_INDEX_RW_PATHS@ by hand here.
# /home/odio/.local is intentionally NOT writable: it contains
# ~/.local/bin/<tool> symlinks (kid → uv-managed binary) and
# ~/.local/share/uv/tools/<tool>/bin/<tool> binaries that are PATH-search
# targets. PR-controlled `just test` runs in this service; if ~/.local
# were writable, an attacker could plant ~/.local/bin/codex or
# ~/.local/bin/kid and have the next reviewer/refresh tick exec it.
# Codex state lives in ~/.codex (separately writable above); claude
# state writes are from interactive operator sessions, not from this
# service. Add a narrower subdir if a future reviewer dependency
# legitimately needs to write under ~/.local.
ReadWritePaths=/home/odio/.pr-reviewer /home/odio/.codex /home/odio/.cache /home/odio/.config /home/odio/.docker @KID_INDEX_RW_PATHS@

[Install]
WantedBy=multi-user.target

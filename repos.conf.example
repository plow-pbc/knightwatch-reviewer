#!/bin/bash
# Tracked GitHub repos for the knightwatch-reviewer bot.
#
# This file (repos.conf.example) is a TEMPLATE. The live config —
# repos.conf — is per-operator, gitignored, and bootstrapped from this
# template by install.sh on first run. Edit repos.conf, not this file,
# unless you're updating the documented shape.
#
# Single source of truth at runtime — sourced by review.sh,
# learn-from-replies.sh, approve-from-replies.sh, re-request-poller.sh,
# and lib/review-one-pr.sh.
#
# To track a new repo: append a line to REPOS and a corresponding entry
# in each of the two maps below (KID_PATHS, SOURCE_PATHS — smoke suite
# enforces a key per repo). Then run ./install.sh on the deployed
# checkout: adding a KID_PATHS entry widens both the kid-refresh and
# pr-reviewer units' ReadWritePaths sandboxes, which only re-render on
# install. A plain `git pull` on the deployed checkout is sufficient
# only when no KID_PATHS key was added.
#
# Per-repo policy (sibling allowlist, product context, review priority,
# dead-code command, strict-typing command) lives in
# <each-repo>/.knightwatch/, NOT here. See lib/knightwatch-config.sh.
#
# KID_PATHS does triple duty:
#   - lib/review-one-pr.sh consults it for kid-prior-art lookups
#     (silently skips when the path has no .keepitdry index).
#   - install.sh renders it into pr-reviewer-kid-refresh.service's
#     ReadWritePaths as `<path>` (full root) via @KID_RW_PATHS@ so
#     the hourly refresher can git-pull + re-index.
#   - install.sh also renders it into pr-reviewer.service's
#     ReadWritePaths as `-<path>/.keepitdry` (optional, narrow) via
#     @KID_INDEX_RW_PATHS@ so review specialists can write chromadb's
#     SQLite WAL inside the index dir without touching the source
#     tree. The narrower review render keeps Codex's inner-sandbox-
#     disabled specialists from getting writes outside the index.

REPOS=(
    "your-org/example-repo"
)

declare -A KID_PATHS=(
    ["your-org/example-repo"]="$HOME/Hacking/example-repo"
)

# Per-repo source-checkout path. Used by lib/review-one-pr.sh to stage
# .codex-scratch/search-roots.md, the cross-repo grep surface for the
# dead-code-search and consumers specialists. Distinct from KID_PATHS
# (kid-index path, not source) — KID_PATHS may point at a separate
# kid-index dir (e.g. <repo>-kid) while SOURCE_PATHS points at the
# repo source checkout where greppable code actually lives. Empty /
# unset = exclude that repo from the search surface.

declare -A SOURCE_PATHS=(
    ["your-org/example-repo"]="$HOME/Hacking/example-repo"
)

diff --git a/app/PhoenixTests/InstallerStateTests.swift b/app/PhoenixTests/InstallerStateTests.swift
index 43fa4e96..9869d332 100644
--- a/app/PhoenixTests/InstallerStateTests.swift
+++ b/app/PhoenixTests/InstallerStateTests.swift
@@ -114,3 +114,81 @@ final class InstallerStateTests: XCTestCase {
         )
     }
 }
+
+// MARK: - Installer window sizing
+
+/// Covers `installerWindowHeight(for:contentHeight:overlayHeight:cap:)` —
+/// the pure helper that drives the installer NSWindow's height. Splash
+/// screens must always render at the design height (530); the connectors
+/// screen must size to its measured intrinsic content (plus the
+/// download-bar overlay when present), capped to the available screen so
+/// the existing ScrollView fallback re-engages on overflow.
+final class InstallerWindowSizeTests: XCTestCase {
+
+    private let designHeight: CGFloat = 530
+    private let cap: CGFloat = 800
+
+    func testSplashScreensUseDesignHeight() {
+        for screen in [InstallerScreen.welcomeInstall, .welcomeFDA, .activation, .connectContext] {
+            XCTAssertEqual(
+                installerWindowHeight(for: screen, contentHeight: 1200, overlayHeight: 200, cap: cap),
+                designHeight,
+                "splash screen \(screen) must ignore measured content and stay at design height"
+            )
+        }
+    }
+
+    func testConnectorsWithoutMeasurementFallsBackToDesignHeight() {
+        XCTAssertEqual(
+            installerWindowHeight(for: .connectors, contentHeight: 0, overlayHeight: 0, cap: cap),
+            designHeight,
+            "before content measures, render at the splash height — never zero"
+        )
+    }
+
+    func testConnectorsSizesToMeasuredContentBelowCap() {
+        XCTAssertEqual(
+            installerWindowHeight(for: .connectors, contentHeight: 480, overlayHeight: 0, cap: cap),
+            480
+        )
+    }
+
+    func testConnectorsAddsOverlayHeightToContent() {
+        // The DownloadBarView overlays the bottom of the ZStack — add its
+        // measured height so settings rows aren't hidden behind it.
+        XCTAssertEqual(
+            installerWindowHeight(for: .connectors, contentHeight: 480, overlayHeight: 70, cap: cap),
+            550
+        )
+    }
+
+    func testConnectorsCapsAtVisibleScreen() {
+        // Content + overlay would push past the cap → cap wins so the
+        // existing ScrollView fallback inside SettingsView re-engages.
+        XCTAssertEqual(
+            installerWindowHeight(for: .connectors, contentHeight: 1500, overlayHeight: 100, cap: cap),
+            cap
+        )
+    }
+
+    func testConnectorsRetryStateGrowsWindowWithBar() {
+        // The retry state grows the DownloadBarView (extra Retry button row)
+        // — the window must grow with it so settings content stays visible.
+        // Assert exact values so a sign-flip in the helper still trips.
+        let normal = installerWindowHeight(for: .connectors, contentHeight: 480, overlayHeight: 60, cap: cap)
+        let retry = installerWindowHeight(for: .connectors, contentHeight: 480, overlayHeight: 100, cap: cap)
+        XCTAssertEqual(normal, 540)
+        XCTAssertEqual(retry, 580)
+    }
+
+    func testSplashIsCappedOnDegenerateVisibleFrame() {
+        // If the visibleFrame collapses (multi-display reconfig, sidecar
+        // with a tiny secondary display), the cap may drop below the 530
+        // splash design height. Splash must respect the cap so it doesn't
+        // overflow the visible screen.
+        XCTAssertEqual(
+            installerWindowHeight(for: .welcomeInstall, contentHeight: 0, overlayHeight: 0, cap: 400),
+            400
+        )
+    }
+}
